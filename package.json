{
	"name": "3d-product-configurator-block",
	"version": "1.0.0",
	"description": "3D product configurator block for WordPress — upload a GLB or FBX model, map parts to colour palettes, let visitors configure and request a quote.",
	"author": "Steil Digital",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"block",
		"three.js",
		"3d",
		"configurator"
	],
	"scripts": {
		"build": "wp-scripts build --webpack-copy-php",
		"start": "wp-scripts start --webpack-copy-php",
		"format": "wp-scripts format",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"make:sample": "node scripts/make-sample-glb.mjs",
		"make:pot": "wp i18n make-pot . languages/3d-product-configurator-block.pot --domain=3d-product-configurator-block --exclude=node_modules,build",
		"plugin-zip": "wp-scripts plugin-zip"
	},
	"files": [
		"build",
		"includes",
		"assets",
		"languages",
		"src",
		"webpack.config.js",
		"3d-product-configurator-block.php",
		"uninstall.php",
		"readme.txt",
		"README.md",
		"LICENSE",
		"NOTICE"
	],
	"devDependencies": {
		"@wordpress/scripts": "^30.23.0",
		"sass": "^1.92.1"
	},
	"dependencies": {
		"three": "^0.180.0"
	}
}
